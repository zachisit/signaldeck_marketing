<script>
(function () {
    var introVideo  = document.querySelector('.item-48 .spacex-intro-video');
    var loopVideo   = document.querySelector('.item-48 .spacex-loop-video');
    var caption     = document.querySelector('.item-48 .spacex-caption');
    var carousel    = document.getElementById('homepagecarousel');
    var introPlayed = false;
    var loopStarted = false;

    if (!introVideo || !carousel) return;

    function showLoopAndCaption() {
        // Fade out intro → brief black screen → caption slides up → loop fades in
        introVideo.style.opacity = '0';
        setTimeout(function () {
            if (caption) caption.classList.add('visible');
            loopVideo.play().catch(function () {});
            loopStarted = true;
            setTimeout(function () {
                loopVideo.style.opacity = '1';
            }, 300);
        }, 450);
    }

    function startIntro() {
        if (introPlayed) {
            // Intro already ran — just make sure loop + caption are visible
            if (caption && !caption.classList.contains('visible')) {
                caption.classList.add('visible');
            }
            loopVideo.style.opacity = '1';
            loopVideo.play().catch(function () {});
            return;
        }
        introPlayed = true;
        introVideo.style.opacity = '1';
        introVideo.currentTime = 2;
        introVideo.play().catch(function () {
            showLoopAndCaption(); // autoplay blocked — skip straight to loop
        });

        introVideo.addEventListener('timeupdate', function onUpdate() {
            if (introVideo.currentTime >= 4.3) {
                introVideo.pause();
                introVideo.removeEventListener('timeupdate', onUpdate);
                showLoopAndCaption();
            }
        });
    }

    // Keep loop running even when carousel rotates to other slides
    loopVideo.addEventListener('pause', function () {
        if (loopStarted) loopVideo.play().catch(function () {});
    });

    // Start immediately if SpaceX is the active slide on load
    if (document.querySelector('.carousel-item.item-48.active')) {
        startIntro();
    }

    // Re-trigger when carousel slides back to SpaceX
    carousel.addEventListener('slid.bs.carousel', function (e) {
        if (e.relatedTarget && e.relatedTarget.classList.contains('item-48')) {
            startIntro();
        }
    });
}());
</script>
    </body>
