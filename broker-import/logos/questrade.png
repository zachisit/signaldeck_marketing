  /* 1. Removes the native "capsule" look of the input itself */
  -webkit-appearance: none;
  appearance: none;
  
  /* 2. Fixes an issue where Safari adds a corner radius by default */
  border-radius: 0; 
}

/* 3. Hides the "X" cancel button */
input[type="search"]::-webkit-search-cancel-button {
  -webkit-appearance: none;
  display: none;
}

/* 4. Hides the magnifying glass icon (if the browser adds one) */
