 <script type="text/javascript">
/** AMPLITUDE TEST **/
/**
 * Variant "on" replaces the default <ul> in #ff-mega-nav-root with a clone
 * Expects: MainMaster "amplitudeReady" / window.isAmplitudeReady.
 * Optional: #ff-mega-nav-experiment data-ff-flag-key and data-ff-condensed-variant override. After the swap, dispatch "ffMegaNavResolved". If the main bundle instantiates
 * AccessibleMegaMenuSEO on DOMContentLoaded, load this file *before* that bundle so the visible <ul> is the final one; otherwise listen for ffMegaNavResolved and re-init the megamenu on #ff-mega-nav-root.
 * Panel toggle init is handled by the standalone "Product Navigation" script (v8).
 * REMOVE THIS SCRIPT when the QUEST-10705 feature flag is retired.
 */
(function () {
  'use strict';

  const root = document.getElementById('ff-mega-nav-experiment');
  const nav = document.getElementById('ff-mega-nav-root');
  /** Condensed <ul> source: <template id="ff-mega-nav-template-condensed"> (preferred) or a hidden
   *  <div id="ff-mega-nav-template-condensed" hidden> wrapping the same <ul> if the CMS strips <template>. */
  function getCondensedMarkupHost() {
    return document.getElementById('ff-mega-nav-template-condensed');
  }

  function getCondensedMarkupNode() {
    const el = getCondensedMarkupHost();
    if (!el) return null;
    if (el.tagName === 'TEMPLATE') {
      return el.content.querySelector('ul.mega-seo-menu--condensed-menu');
    }
    return el.querySelector('ul.mega-seo-menu--condensed-menu');
  }

  function hasCondensedMarkup() {
    return getCondensedMarkupNode() != null;
  }

  if (!root || !nav) return;

  /* Until the flag resolves, keep the live nav out of the accessibility tree (matches CSS hide). */
  nav.setAttribute('aria-hidden', 'true');

  const FLAG_KEY = root.getAttribute('data-ff-flag-key') || 'qcom_experiment_mega-navigation-v1';
  const VARIANT_ON = root.getAttribute('data-ff-condensed-variant') || 'on';
  const FALLBACK_MS = 5000;

  let finished = false;
  let failSafe = null;
  let pollId = null;
  let defaultMenuSnapshot = null;

  function getMenuUl() {
    return nav.querySelector('ul.mega-seo-menu');
  }

  function ensureDefaultSnapshot() {
    if (defaultMenuSnapshot != null) return;
    const ul = getMenuUl();
    if (ul && !ul.classList.contains('mega-seo-menu--condensed-menu')) {
      defaultMenuSnapshot = ul.cloneNode(true);
    }
  }

  function replaceWithCondensedMenu() {
    ensureDefaultSnapshot();
    const live = getMenuUl();
    if (!live || live.classList.contains('mega-seo-menu--condensed-menu')) return;
    const raw = getCondensedMarkupNode();
    if (!raw) return;
    const next = raw.cloneNode(true);
    live.replaceWith(next);
    nav.setAttribute('data-qt-mega-nav', 'condensed-menu');
  }

  function replaceWithDefaultMenu() {
    const live = getMenuUl();
    if (!live) return;
    if (!live.classList.contains('mega-seo-menu--condensed-menu')) return;
    if (!defaultMenuSnapshot) return;
    live.replaceWith(defaultMenuSnapshot.cloneNode(true));
    nav.removeAttribute('data-qt-mega-nav');
  }

  function normalizeVariantId(v) {
    if (v == null) return null;
    if (typeof v === 'string') return v.trim();
    if (v.value != null) return String(v.value).trim();
    if (v.key != null) return String(v.key).trim();
    if (v.payload) {
      const p = v.payload.variant || v.payload.value || v.payload.key;
      if (p != null) return String(p).trim();
    }
    return null;
  }

  function getVariant() {
    const raw =
      window.amplitudeFlags?.[FLAG_KEY] ??
      (typeof window.amplitudeExperiment?.variant === 'function'
        ? window.amplitudeExperiment.variant(FLAG_KEY)
        : null) ??
      null;
    if (raw == null) return null;
    if (typeof raw === 'string') return raw.trim() || null;
    return normalizeVariantId(raw);
  }

  function pushGtm(variantId, source) {
    try {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'feature_flag_active',
        feature_flag: FLAG_KEY,
        variant: variantId,
        feature_flag_source: source,
      });
    } catch (_) {
      /* ignore */
    }
  }

  function setVisibility(useCondensed, source) {
    if (finished) return;
    finished = true;
    if (failSafe != null) {
      clearTimeout(failSafe);
      failSafe = null;
    }
    if (pollId != null) {
      clearInterval(pollId);
      pollId = null;
    }

    if (useCondensed) {
      replaceWithCondensedMenu();
      root.classList.remove('ff-ff--show-default');
      root.classList.add('ff-ff--show-condensed');
      pushGtm(VARIANT_ON, source);
    } else {
      replaceWithDefaultMenu();
      root.classList.remove('ff-ff--show-condensed');
      root.classList.add('ff-ff--show-default');
      const v = getVariant();
      pushGtm(v != null ? String(v) : 'control', source);
    }

    root.classList.remove('ff-ff--amp-lock');
    root.classList.add('ff-ff--resolved');
    nav.setAttribute('aria-hidden', 'false');

    try {
      window.dispatchEvent(
        new CustomEvent('ffMegaNavResolved', {
          detail: { useCondensed: useCondensed, flagKey: FLAG_KEY, source: source },
        }),
      );
      window.dispatchEvent(
        new CustomEvent('ffMegaNavMarkupSwapped', {
          detail: { useCondensed: useCondensed, flagKey: FLAG_KEY, source: source, nav: nav },
        }),
      );
    } catch (_) {
      /* ignore */
    }
  }

  function variantIsCondensed(v) {
    if (v == null) return false;
    return String(v).trim().toLowerCase() === String(VARIANT_ON).trim().toLowerCase();
  }

  function showDefault(source) {
    setVisibility(false, source);
  }

  function showCondensed(source) {
    setVisibility(true, source);
  }

  function tryDecide(source) {
    if (finished) return;
    const v = getVariant();
    if (v == null) {
      return;
    }
    if (variantIsCondensed(v)) {
      if (hasCondensedMarkup()) {
        showCondensed(source != null ? String(source) : 'amplitude');
      } else {
        showDefault(String(source != null ? source : 'amplitude') + '-condensed-template-missing');
      }
      return;
    }
    showDefault('amplitude-other');
  }

  function start() {
    const tick = function () {
      tryDecide('poll');
    };

    if (window.isAmplitudeReady) {
      requestAnimationFrame(tick);
      setTimeout(tick, 0);
      for (var j = 1; j <= 20; j += 1) {
        setTimeout(tick, j * 50);
      }
    }

    document.addEventListener(
      'amplitudeReady',
      function onAmplitude() {
        tryDecide('amplitudeReady');
      },
      { once: true },
    );

    pollId = setInterval(tick, 100);

    failSafe = setTimeout(function () {
      if (pollId != null) {
        clearInterval(pollId);
        pollId = null;
      }
      if (!finished) {
        showDefault('fallback-timeout');
      }
    }, FALLBACK_MS);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start, { once: true });
  } else {
    start();
  }

  // If the flag pipeline never completed (e.g. amplitudeReady missing), the bar must not stay
  // in a "locked" state. Unlock and keep the default <ul> (same as 5s fallback, extra safety).
  setTimeout(function ffMegaNavStallGuard() {
    if (finished) return;
    showDefault('failsafe-stall-guard');
  }, 10000);
})();

</script><script type="text/javascript">
/**
 * FF mega nav panel toggle init — standalone script
 * Firefox: AccessibleMegaMenuSEO initializes on the original <ul> before the Amplitude
 * swap, so condensed buttons get no handlers — we add them here.
 * Chrome: Amplitude resolves first, swap happens, then AccessibleMegaMenuSEO initializes
 * on the condensed <ul> naturally — we must not interfere.
 * Detection: AccessibleMegaMenuSEO.create() sets aria-controls on every button it owns.
 * At click time, if aria-controls is present we defer to AccessibleMegaMenuSEO; if not,
 * we handle the toggle ourselves using the same class pattern (mega-seo-menu__top-nav-item--open
 * on the <li> and .open on the panel).
 * Uses ffPanelInitV8 flag — does not conflict with any previously deployed version.
 * REMOVE THIS SCRIPT when the QUEST-10705 feature flag is retired.
 */
(function () {
  'use strict';

  function initCondensedPanelToggles(nav) {
    var ul = nav.querySelector('ul.mega-seo-menu--condensed-menu');
    if (!ul) return;

    if (ul.dataset.ffPanelInitV8) return;
    ul.dataset.ffPanelInitV8 = '1';

    var dropdownItems = [];
    ul.querySelectorAll('li.mega-seo-menu__top-nav-item').forEach(function (li) {
      var panel = li.querySelector('.mega-seo-menu__panel');
      var btn = li.querySelector('button');
      // Dropdown panels have no style="display:none"; direct-link items have no panel at all (v8)
      if (panel && btn && panel.style.display !== 'none') {
        dropdownItems.push({ li: li, btn: btn, panel: panel });
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-haspopup', 'true');
      }
    });

    function closeAll() {
      dropdownItems.forEach(function (item) {
        item.li.classList.remove('mega-seo-menu__top-nav-item--open');
        item.panel.classList.remove('open');
        item.btn.setAttribute('aria-expanded', 'false');
      });
    }

    ul.addEventListener('click', function (e) {
      var btn = e.target.closest('button');
      if (!btn) return;
      // aria-controls is set exclusively by AccessibleMegaMenuSEO.create() — if present,
      // it has already initialized this button and will handle the toggle itself
      if (btn.hasAttribute('aria-controls')) return;
      var match = dropdownItems.find(function (item) { return item.btn === btn; });
      if (!match) return;
      var isOpen = match.li.classList.contains('mega-seo-menu__top-nav-item--open');
      closeAll();
      if (!isOpen) {
        match.li.classList.add('mega-seo-menu__top-nav-item--open');
        match.panel.classList.add('open');
        match.btn.setAttribute('aria-expanded', 'true');
      }
    });

    document.addEventListener('click', function (e) {
      if (!ul.contains(e.target)) {
        closeAll();
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeAll();
      }
    });
  }

  var nav = document.getElementById('ff-mega-nav-root');
  if (!nav) return;

  // If this script loads after the swap already happened, init immediately
  var root = document.getElementById('ff-mega-nav-experiment');
  if (root && root.classList.contains('ff-ff--show-condensed')) {
    initCondensedPanelToggles(nav);
    return;
  }

  // Otherwise wait for the swap event
  window.addEventListener('ffMegaNavMarkupSwapped', function (e) {
    if (e.detail && e.detail.useCondensed) {
      initCondensedPanelToggles(e.detail.nav || nav);
    }
  }, { once: true });

})();

</script><script type="text/javascript">

