  #banner-global .banner__content {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    column-gap: 4px;
  }

  #banner-global .banner__text {
    flex: 1 1 auto;
    min-width: 0;
    padding-left: 0 !important;
    margin-left: 0 !important;
  }

  #banner-global .banner__text::before,
  #banner-global .banner__text-title::before,
  #banner-global .banner__text-title a::before,
  #banner-global .banner__content::before {
    display: none !important;
