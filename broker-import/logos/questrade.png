</style><style type="text/css" media="all">/** AMPLITUDE TEST **/

/* --- Top bar: match "scrolled" flex gap in default (top of page) state ---- */
/* Beats: .mega-seo-menu { gap: 4px } and .mega-seo-menu { gap: 8px !important } */
[data-qt-mega-nav='condensed-menu'] .mega-seo-menu--condensed-menu,
[data-qt-mega-nav='condensed-menu'] .mega-seo-menu.mega-seo-menu--condensed-menu {
  gap: 20px !important;
}

/* --- v8: Direct-link <a> items (Why Questrade, Learning) -------------------
   In v8 these are plain <a class="mega-seo-menu__top-nav-item--link-direct ...">
   elements with no button wrapper and no panel div, so AccessibleMegaMenuSEO
   does not attach togglePanel to them. The rules below mirror the sizing of
   button.mega-seo-menu__top-nav-item--link so they render identically. ------- */
[data-qt-mega-nav='condensed-menu'] .mega-seo-menu__top-nav-item--link-direct {
  display: flex;
  align-items: center;
  padding: 0 !important;
  margin: 0 !important;
  text-decoration: none;
  color: inherit;
}

.mega-header-seo:not(.scrolling-down)
  [data-qt-mega-nav='condensed-menu']
  .mega-seo-menu__top-nav-item--link-direct {
  height: 73px;
}

.mega-header-seo.scrolling-down
  [data-qt-mega-nav='condensed-menu']
  .mega-seo-menu__top-nav-item--link-direct {
  display: flex;
  align-items: center;
  height: 72px;
  padding: 0;
}

/* ============== Start Trading panel (2-column) — inline fallbacks ======= */
/* <ul> child order: 1 search, 2 Start Trading, 3 Why, 4 Programs, 5 Learning */
[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .bg-grey-100 {
  background-color: #fff !important;
  width: 100%;
  box-sizing: border-box;
  padding: 24px 32px 32px;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .bg-grey-100
  > div:first-of-type {
  display: flex;
  flex-wrap: wrap;
  gap: 48px 72px;
  align-items: flex-start;
  max-width: 900px;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .bg-grey-100
  > div:first-of-type
  > div:first-of-type {
  flex: 1 1 220px;
  min-width: 0;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .mega-seo-menu__panel-group--link-heading:first-of-type {
  display: block;
  margin: 0 0 14px;
  line-height: 1.25;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .mega-seo-menu__panel-container--wrapper-cards__subheading {
  margin: 0;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .bg-grey-100
  a.mega-seo-menu__panel-group--link-subheading__account {
  color: #5c5c5c;
  font-weight: 400;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .bg-grey-100
  > div:first-of-type
  > div:nth-of-type(2) {
  flex: 0 1 auto;
  min-width: 160px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  align-items: flex-start;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(2)
  .bg-grey-100
  > div:first-of-type
  > div:nth-of-type(2)
  .mega-seo-menu__panel-group--link-heading {
  display: inline-block;
  margin: 0;
  line-height: 1.25;
}

/* ============== Programs and Promotions panel — inline fallbacks ========= */
[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(4)
  .bg-grey-100 {
  background-color: #fff !important;
  width: 100%;
  box-sizing: border-box;
  padding: 24px 32px 32px;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(4)
  .bg-grey-100
  > div {
  max-width: 420px;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(4)
  .bg-grey-100
  .mega-seo-menu__panel-container--wrapper-cards__subheading:first-of-type {
  font-weight: 700;
  color: #1a1a1a;
  margin: 0 0 16px;
  line-height: 1.3;
  font-size: 1rem;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(4)
  .bg-grey-100
  p.mega-seo-menu__panel-container--wrapper-cards__subheading:not(:first-of-type) {
  margin: 0;
}

[data-qt-mega-nav='condensed-menu']
  .mega-seo-menu
  > li.mega-seo-menu__top-nav-item:nth-child(4)
  .bg-grey-100
  a.mega-seo-menu__panel-group--link-subheading__account {
  color: #5c5c5c;
  font-weight: 400;
}

/* --- Desktop: remove core 50/50 grey–white panel gradient (layout/_menu-seo.scss
     .menu-seo__panel @ desktop) so the dropdown reads as one full-width white band. --- */
@media (min-width: 992px) {
  [data-qt-mega-nav='condensed-menu'] .mega-seo-menu__panel,
  [data-qt-mega-nav='condensed-menu'] .mega-seo-menu__panel.open {
    background: #ffffff !important;
    background-color: #ffffff !important;
    background-image: none !important;
  }
}
</style><style type="text/css" media="all">/** AMPLITUDE TEST **/
/**wrapper styles for the condensed mega nav feature flag **/

#ff-mega-nav-experiment {
  position: relative;
  width: 100%;
}

/*
 * While Amplitude is unresolved (.ff-ff--amp-lock without .ff-ff--resolved), hide the live <nav> so users do not see the default <ul> flash before the condensed swap.
 */
#ff-mega-nav-experiment.ff-ff--amp-lock:not(.ff-ff--resolved) #ff-mega-nav-root {
  visibility: hidden;
  pointer-events: none;
}

/* Hidden source for condensed <ul> when using <div>. Keeps the duplicate menu off-screen if an editor strips the `hidden` attribute. */
#ff-mega-nav-template-condensed.ff-mega-nav-condensed-source,
.ff-mega-nav-condensed-source {
  display: none !important;
}
</style><style type="text/css" media="all">@media (max-width: 767px) {
  #banner-global .base-layout {
    padding-left: 0 !important;
