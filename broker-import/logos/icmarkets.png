<style>
.carousel-item.item-48 {
    background: #000;
    position: relative;
    overflow: hidden;
    pointer-events: none;
}
.item-48 .spacex-caption * {
    pointer-events: auto;
}
.item-48 .spacex-intro-video,
.item-48 .spacex-loop-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
}
.item-48 .spacex-intro-video {
    z-index: 1;
    opacity: 1;
    transition: opacity 0.5s ease;
}
.item-48 .spacex-loop-video {
    z-index: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
}
.item-48 .spacex-mobile-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
}
.item-48 .spacex-mobile-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.item-48 .spacex-caption {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.7s ease, transform 0.7s ease;
}
.item-48 .spacex-caption.visible {
    opacity: 1;
    transform: translateY(0);
}
.item-48 .spacex-desc {
    color: #DFDFDF;
    text-align: center;
    font-family: "DM Sans", sans-serif;
    font-size: 22px;
    font-style: normal;
    margin: 0;
}
@media (max-width: 575px) {
    .item-48 .spacex-caption {
        animation: spacexSlideUp 0.7s ease 0.2s forwards;
    }
}
@keyframes spacexSlideUp {
    from { opacity: 0; transform: translateY(50px); }
    to   { opacity: 1; transform: translateY(0); }
}
</style>
        
